# 使用轻量级的 Python 3.10 镜像
FROM python:3.10-slim

# 设置工作目录
WORKDIR /app

# 复制依赖文件并安装
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制你的后端代码（修改为你实际的后端文件名）
COPY day7_fastapi_pdf_rag.py .
COPY .env .

# 暴露 8000 端口
EXPOSE 8000

# 启动 FastAPI
CMD ["uvicorn", "day7_fastapi_pdf_rag:app", "--host", "0.0.0.0", "--port", "8000"]